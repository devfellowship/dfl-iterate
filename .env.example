# ==============================================
# dfl-iterate — Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values.
# See repo-contract.yaml for full variable documentation.

# --- Supabase (required for backend integration) ---
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Observability (OpenTelemetry) ---
# API key for the OTel collector endpoint
VITE_OTEL_API_KEY=your-api-key-here
# Enable/disable tracing and metrics export
VITE_OTEL_ENABLED=true

# --- Secrets Management ---
# Secrets are managed via Infisical in staging/production.
# Local development uses this .env file as the source of truth.
# See: https://infisical.com/docs
